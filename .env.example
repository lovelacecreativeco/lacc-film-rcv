# Copy this file to .env and fill in your values before running.
# Never commit .env to version control.

# Strong random string — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-something-random

# PostgreSQL password
DB_PASSWORD=change-me-too

# Admin panel password (shown at /admin)
ADMIN_PASSWORD=your-admin-password-here

# Host port to expose the app on (default 5000)
# APP_PORT=5000
